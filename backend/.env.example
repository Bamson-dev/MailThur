# Server
PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# Frontend URL (also included in CORS allowlist)
FRONTEND_URL=http://localhost:3000

# Comma-separated CORS allowlist (override per environment)
CORS_ALLOWED_ORIGINS=https://mailthur.com,https://staging.mailthur.com,http://localhost:3000

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback

# Session signing (min 32 chars) — REQUIRED for OAuth inbox connection
SESSION_SECRET=replace-with-a-random-secret-at-least-32-chars-long

# Optional cookie domain for cross-subdomain sessions (e.g. .mailthur.com)
# COOKIE_DOMAIN=.mailthur.com

# Optional: public URL for unsubscribe links in outgoing emails
# Staging: https://staging-backend.mailthur.com
# Production: https://backend.mailthur.com
PUBLIC_BACKEND_URL=https://staging-backend.mailthur.com

# Billing — Paystack (Nigeria) and Flutterwave (international)
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret
PAYSTACK_STARTER_PLAN=PLN_your_starter_plan_code
PAYSTACK_GROWTH_PLAN=PLN_your_growth_plan_code
PAYSTACK_AGENCY_PLAN=PLN_your_agency_plan_code
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-your_flutterwave_secret_key
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-your_flutterwave_public_key
