# Public environment variables (safe for client-side exposure)
# These values are embedded in the browser bundle — never put secrets here.

NEXT_PUBLIC_API_URL=http://localhost:4000
# Fixed ISO launch timestamp (not relative — survives page reloads)
NEXT_PUBLIC_LAUNCH_DATE=2026-06-21T16:00:00.000Z
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# SECURITY NOTE:
# All four variables above are intentionally public:
# - NEXT_PUBLIC_API_URL: API base URL (not a secret)
# - NEXT_PUBLIC_SUPABASE_URL: Supabase project URL (not a secret)
# - NEXT_PUBLIC_SUPABASE_ANON_KEY: Supabase anon key, designed for client use with RLS
# - NEXT_PUBLIC_GOOGLE_CLIENT_ID: OAuth client ID, designed for client-side OAuth flows
#
# NEVER use NEXT_PUBLIC_ prefix for:
# - API keys, service keys, or secrets
# - Supabase service role key
# - Google client secret
# - JWT signing secrets
# - Database connection strings
# - Redis URLs with credentials
